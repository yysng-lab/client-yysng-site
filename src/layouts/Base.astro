---
import "../styles/theme.css";
import "../styles/global.css";

import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  noChrome?: boolean;
  noindex?: boolean;
}

const {
  title = "YY Sng",
  description = "Operator-grade builder. Calm systems. Practical outcomes.",
  canonical,
  noChrome = false,
  noindex = false,
} = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Fonts: Sora headlines, IBM Plex Sans body, IBM Plex Mono labels -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=IBM+Plex+Sans:wght@400;500;600&family=Sora:wght@500;600;650;700&display=swap"
      rel="stylesheet"
    />

    {/* Canonical */}
    <link rel="canonical" href={Astro.props.canonical ?? Astro.url.href} />

    {/* Open Graph */}
    <meta property="og:title" content={Astro.props.ogTitle ?? title} />
    <meta property="og:description" content={Astro.props.ogDescription ?? description} />
    <meta property="og:type" content={Astro.props.ogType ?? "website"} />
    <meta property="og:url" content={Astro.props.canonical ?? Astro.url.href} />
    <meta property="og:locale" content="en_SG" />
    <meta property="og:site_name" content="YY Sng" />
    <meta property="og:image" content={Astro.props.ogImage ?? "https://yysng.me/images/yy/og-main.webp"} />

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={Astro.props.ogTitle ?? title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={Astro.props.ogImage ?? "https://yysng.me/images/yy/og-main.webp"} />

    {/* Optional: keywords */}
    {Astro.props.keywords && <meta name="keywords" content={Astro.props.keywords} />}

    {/* JSON-LD blocks (array of objects) */}
    {Array.isArray(Astro.props.jsonLd) && Astro.props.jsonLd.map((obj) => (
      <script type="application/ld+json" set:html={JSON.stringify(obj)} />
    ))}
    {noindex && (
      <meta name="robots" content="noindex, nofollow" />
    )}

    <slot name="head" />
  </head>

  <body class="min-h-screen relative">
    <!-- global header -->
   {!noChrome && <Header />}

    <!-- page content -->
    <main class={noChrome ? "min-h-screen" : "pt-16"}>
      <slot />
    </main>

    <!-- global footer -->
   {!noChrome && <Footer />}

    <!-- Alpine -->
    <script
      is:inline
      src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"
      defer
    ></script>

    <!-- reveal logic (headers only) -->
    {!noChrome && (
  <script is:inline>
    (() => {
      const run = () => {
        if (!("IntersectionObserver" in window)) {
          // Fallback: reveal everything immediately
          document.querySelectorAll("[data-reveal-item]").forEach(el => {
            el.classList.add("reveal", "is-visible");
          });
          document.querySelectorAll("[data-motion-reveal]").forEach(el => {
            el.classList.add("motion-visible");
          });
          return;
        }

        // ── Legacy header reveals (case studies, etc.) ──────────────────
        const legacyEls = Array.from(document.querySelectorAll("[data-reveal-item]"));
        if (legacyEls.length > 0) {
          legacyEls.forEach(el => el.classList.add("reveal"));
          const legacyIo = new IntersectionObserver((entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add("is-visible");
                legacyIo.unobserve(e.target);
              }
            }
          }, { threshold: 0.2, rootMargin: "0px 0px -10% 0px" });
          legacyEls.forEach(el => legacyIo.observe(el));
        }

        // ── Staggered scroll reveals ────────────────────────────────────
        const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const motionEls = Array.from(document.querySelectorAll("[data-motion-reveal]"));
        if (motionEls.length === 0) return;

        if (reduced) {
          // Reduced motion: content stays visible, skip hiding
          return;
        }

        // Assign stagger delays from parent data-motion-group
        document.querySelectorAll("[data-motion-group]").forEach(group => {
          const stagger = parseInt(group.dataset.motionStagger || "80", 10);
          Array.from(group.querySelectorAll("[data-motion-reveal]")).forEach((el, i) => {
            el.style.setProperty("--motion-delay", i * stagger + "ms");
          });
        });

        // Set initial hidden state (JS guard — content visible before this runs)
        motionEls.forEach(el => el.classList.add("motion-ready"));

        const motionIo = new IntersectionObserver((entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("motion-visible");
              motionIo.unobserve(e.target);
            }
          }
        }, { threshold: 0.08, rootMargin: "0px 0px -4% 0px" });

        motionEls.forEach(el => motionIo.observe(el));
      };

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", run, { once: true });
      } else {
        run();
      }
    })();
  </script>
)}
  </body>
</html>