---
export const prerender = false;

import Base from "../layouts/Base.astro";
import Hero from "../components/home/Hero.astro";
import FinalCTA from "../components/home/FinalCTA.astro";
import WhatIBuild from "../sections/WhatIBuild.astro";
import WhereIOperate from "../sections/WhereIOperate.astro";
import FromTheField from "../sections/FromTheField.astro";

// ── Supabase (edge-safe: plain fetch against REST API) ──────────────────────
const env = Astro.locals?.runtime?.env ?? {};
const SUPABASE_URL =
  (env as Record<string, string>).SUPABASE_URL ?? import.meta.env.SUPABASE_URL ?? "";
const SUPABASE_ANON_KEY =
  (env as Record<string, string>).SUPABASE_ANON_KEY ?? import.meta.env.SUPABASE_ANON_KEY ?? "";

const supabaseHeaders = {
  apikey: SUPABASE_ANON_KEY,
  Authorization: `Bearer ${SUPABASE_ANON_KEY}`,
  "Content-Type": "application/json",
};

async function supabaseFetch(path: string) {
  if (!SUPABASE_URL || !SUPABASE_ANON_KEY) return null;
  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/${path}`, {
      headers: supabaseHeaders,
    });
    if (!res.ok) return null;
    return res.json();
  } catch {
    return null;
  }
}

// Section 2 — What I Build
interface System {
  name: string;
  status: string;
  public_description: string | null;
}
const systemsRaw = await supabaseFetch(
  "systems?public=eq.true&select=name,status,public_description&order=status"
);
const systems: System[] = Array.isArray(systemsRaw) ? systemsRaw : [];

// Section 4 — From the Field
// Fetch published posts + all their performance snapshots, join in JS
interface PerfSnapshot { impressions: number | null }
interface PostRaw {
  post_id: string;
  content: string;
  linkedin_url: string;
  published_at: string | null;
  linkedin_performance: PerfSnapshot[];
}
const since60d = new Date(Date.now() - 60 * 24 * 60 * 60 * 1000).toISOString();
const postsRaw = await supabaseFetch(
  `linkedin_posts?select=post_id,content,linkedin_url,published_at,linkedin_performance(impressions)&linkedin_url=not.is.null&status=in.(published,approved)&published_at=gte.${since60d}`
);
const posts = (Array.isArray(postsRaw) ? (postsRaw as PostRaw[]) : [])
  .map((p) => ({
    post_id: p.post_id,
    content: p.content,
    linkedin_url: p.linkedin_url,
    published_at: p.published_at,
    peak_impressions: p.linkedin_performance.reduce(
      (max, s) => Math.max(max, s.impressions ?? 0),
      0
    ),
  }))
  .sort((a, b) => b.peak_impressions - a.peak_impressions)
  .slice(0, 3);

// ── Static content (from brief) ─────────────────────────────────────────────
const heroData = {
  title: "Most AI conversations happen in decks. Mine happen in production.",
  subtitle:
    "I'm YY — COO of Laimi, building AI infrastructure for Asia's travel loyalty market. I run agent systems across multiple ventures and document what actually happens when AI meets real operations — not the theory, the friction.",
  meta: "This site updates itself. Same system I build for others.",
  cta: { label: "Let's talk", href: "https://yysng.me/card/yysng" },
};

const ctaData = {
  heading: "Less AI theory. More AI in production.",
  button: { label: "Let's talk", href: "https://yysng.me/card/yysng" },
};

// ── SEO ─────────────────────────────────────────────────────────────────────
const seo = {
  title: "YY Sng — AI Operator",
  description:
    "COO of Laimi. Building AI infrastructure for Asia's travel loyalty market. Agent systems in production across multiple ventures.",
  canonical: "https://yysng.me/",
  ogTitle: "Most AI conversations happen in decks. Mine happen in production.",
  ogDescription:
    "COO of Laimi. Building AI infrastructure for Asia's travel loyalty market. Agent systems in production across multiple ventures.",
  ogType: "website",
  ogImage: "https://yysng.me/images/yy/og-main.webp",
  keywords:
    "AI operator, AI infrastructure, travel loyalty, Laimi, agent systems, production AI",
};

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Person",
    "@id": "https://yysng.me/#yy",
    name: "YY Sng",
    givenName: "Yan Yuan",
    familyName: "Sng",
    jobTitle: "COO and AI Operator",
    description:
      "AI Operator building and running agent systems across real businesses in Southeast Asia. COO of Laimi, documenting what actually happens when AI meets real operations.",
    image: "https://yysng.me/images/yy/hero-sit.jpg",
    url: "https://yysng.me",
    worksFor: {
      "@type": "Organization",
      name: "Laimi",
      url: "https://laimi.co",
    },
    knowsAbout: [
      "AI agent systems",
      "AI operations",
      "travel loyalty infrastructure",
      "Southeast Asia",
      "business automation",
    ],
    sameAs: ["https://www.linkedin.com/in/yanyuansng/"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "YY Sng",
    url: "https://yysng.me/",
    inLanguage: "en",
  },
];
---

<Base
  title={seo.title}
  description={seo.description}
  canonical={seo.canonical}
  ogTitle={seo.ogTitle}
  ogDescription={seo.ogDescription}
  ogType={seo.ogType}
  ogImage={seo.ogImage}
  keywords={seo.keywords}
  jsonLd={jsonLd}
>
  <main>

    <!-- 1. Hero -->
    <Hero data={heroData} />

    <!-- 2. What I Build -->
    <WhatIBuild systems={systems} />

    <!-- 3. Where I Operate -->
    <WhereIOperate />

    <!-- 4. From the Field -->
    <FromTheField posts={posts} />

    <!-- 5. CTA -->
    <FinalCTA data={ctaData} />

  </main>
</Base>
